<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="-0.02"
            android:text="Quản lý kho hàng"
            android:textColor="@color/admin_text_main"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="Quản lý danh mục sản phẩm, số lượng tồn kho và giá bán của gian hàng."
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewProduct"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/admin_primary"
            android:paddingHorizontal="20dp"
            android:text="Thêm sản phẩm"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconSize="20dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/admin_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/searchLayout"
                    style="@style/Widget.Material3.TextInputLayout.FilledBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="#F4F6F8"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_search_thin"
                    app:startIconTint="@color/admin_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tìm kiếm sản phẩm..."
                        android:inputType="text"
                        android:paddingVertical="12dp"
                        android:textColor="@color/admin_text_main"
                        android:textColorHint="@color/admin_text_secondary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterCategory"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="12dp"
                            android:text="Danh mục"
                            android:textAllCaps="false"
                            android:textColor="@color/admin_text_main"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/admin_light_green"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_chevron_down_thin"
                            app:iconGravity="end"
                            app:iconPadding="6dp"
                            app:iconSize="14dp"
                            app:iconTint="@color/admin_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterActive"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="12dp"
                            android:text="Trạng thái"
                            android:textAllCaps="false"
                            android:textColor="@color/admin_text_main"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/admin_light_green"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_chevron_down_thin"
                            app:iconGravity="end"
                            app:iconPadding="6dp"
                            app:iconSize="14dp"
                            app:iconTint="@color/admin_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterPrescription"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="12dp"
                            android:text="Kê đơn"
                            android:textAllCaps="false"
                            android:textColor="@color/admin_text_main"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/admin_light_green"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_chevron_down_thin"
                            app:iconGravity="end"
                            app:iconPadding="6dp"
                            app:iconSize="14dp"
                            app:iconTint="@color/admin_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterFeatured"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="12dp"
                            android:text="Nổi bật"
                            android:textAllCaps="false"
                            android:textColor="@color/admin_text_main"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/admin_light_green"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_chevron_down_thin"
                            app:iconGravity="end"
                            app:iconPadding="6dp"
                            app:iconSize="14dp"
                            app:iconTint="@color/admin_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterBestSeller"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="12dp"
                            android:text="Bán chạy"
                            android:textAllCaps="false"
                            android:textColor="@color/admin_text_main"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/admin_light_green"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_chevron_down_thin"
                            app:iconGravity="end"
                            app:iconPadding="6dp"
                            app:iconSize="14dp"
                            app:iconTint="@color/admin_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterStock"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="12dp"
                            android:text="Tồn kho"
                            android:textAllCaps="false"
                            android:textColor="@color/admin_text_main"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/admin_light_green"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_chevron_down_thin"
                            app:iconGravity="end"
                            app:iconPadding="6dp"
                            app:iconSize="14dp"
                            app:iconTint="@color/admin_primary" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvInventory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp" />
    </FrameLayout>
</LinearLayout>
