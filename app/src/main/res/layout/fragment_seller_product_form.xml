<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/on_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Thêm sản phẩm"
            android:textColor="@color/on_surface"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:hint="Tên sản phẩm"
            android:inputType="textCapWords"
            android:paddingHorizontal="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etBrand"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:hint="Thương hiệu"
            android:inputType="textCapWords"
            android:paddingHorizontal="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etManufacturer"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:hint="Nhà sản xuất"
            android:inputType="textCapWords"
            android:paddingHorizontal="14dp"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etPrice"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/round_corner_item"
                android:backgroundTint="@color/white"
                android:hint="Giá"
                android:inputType="numberDecimal"
                android:paddingHorizontal="14dp"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/etSalePrice"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/round_corner_item"
                android:backgroundTint="@color/white"
                android:hint="Giá sale"
                android:inputType="numberDecimal"
                android:paddingHorizontal="14dp"
                android:textSize="16sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etStock"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:hint="Số lượng tồn kho"
            android:inputType="number"
            android:paddingHorizontal="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etImages"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:gravity="top"
            android:hint="Link ảnh, cách nhau bằng dấu phẩy hoặc xuống dòng"
            android:inputType="textMultiLine|textUri"
            android:padding="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:gravity="top"
            android:hint="Mô tả"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etUsage"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:gravity="top"
            android:hint="Cách dùng"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etIndications"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:gravity="top"
            android:hint="Chỉ định"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etContraindications"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:gravity="top"
            android:hint="Chống chỉ định"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/cbRequiresPrescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Yêu cầu đơn thuốc" />

        <CheckBox
            android:id="@+id/cbFeatured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sản phẩm nổi bật" />

        <CheckBox
            android:id="@+id/cbBestSeller"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bán chạy" />

        <CheckBox
            android:id="@+id/cbActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đang bán" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Thêm sản phẩm"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />
    </LinearLayout>
</ScrollView>
