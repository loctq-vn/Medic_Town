<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_back"
            app:tint="@color/on_surface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Quản lý sản phẩm"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvFormTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đăng ký sản phẩm"
                android:textColor="@color/on_surface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cập nhật thông tin sản phẩm, hình ảnh và tồn kho cho gian hàng."
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_admin_form_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/AdminFormSectionTitle"
                    android:text="Hình ảnh &amp; hiển thị" />

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="16dp"
                    android:text="Ảnh sản phẩm" />

                <LinearLayout
                    android:id="@+id/layoutImageUploadArea"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_admin_upload_area"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="Chạm để chọn ảnh từ điện thoại"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Ảnh sẽ được tải lên và lưu vào danh sách sản phẩm"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSelectedProductImages"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/etImages"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Đang bán"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hiển thị sản phẩm trong gian hàng"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/cbActive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_form_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/AdminFormSectionTitle"
                    android:text="Thông tin cơ bản" />

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="16dp"
                    android:text="Tên sản phẩm *" />

                <EditText
                    android:id="@+id/etName"
                    style="@style/AdminFormInput"
                    android:layout_marginTop="8dp"
                    android:hint="VD: Viên uống bổ sung vitamin C"
                    android:inputType="textCapWords" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/AdminFormLabel"
                            android:text="Danh mục" />

                        <Spinner
                            android:id="@+id/spCategory"
                            style="@style/AdminFormSpinner"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/AdminFormLabel"
                            android:text="Danh mục con *" />

                        <Spinner
                            android:id="@+id/spSubcategory"
                            style="@style/AdminFormSpinner"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/AdminFormLabel"
                            android:text="Thương hiệu" />

                        <EditText
                            android:id="@+id/etBrand"
                            style="@style/AdminFormInput"
                            android:layout_marginTop="8dp"
                            android:hint="VD: Zen Labs"
                            android:inputType="textCapWords" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/AdminFormLabel"
                            android:text="Nhà sản xuất" />

                        <EditText
                            android:id="@+id/etManufacturer"
                            style="@style/AdminFormInput"
                            android:layout_marginTop="8dp"
                            android:hint="Tên nhà sản xuất"
                            android:inputType="textCapWords" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_form_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/AdminFormSectionTitle"
                    android:text="Giá &amp; tồn kho" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/AdminFormLabel"
                            android:text="Giá bán *" />

                        <EditText
                            android:id="@+id/etPrice"
                            style="@style/AdminFormInput"
                            android:layout_marginTop="8dp"
                            android:hint="150000"
                            android:inputType="numberDecimal" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/AdminFormLabel"
                            android:text="Giá khuyến mãi" />

                        <EditText
                            android:id="@+id/etSalePrice"
                            style="@style/AdminFormInput"
                            android:layout_marginTop="8dp"
                            android:hint="Nhỏ hơn giá bán"
                            android:inputType="numberDecimal" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="14dp"
                    android:text="Số lượng tồn kho *" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etStock"
                        style="@style/AdminFormInput"
                        android:layout_width="0dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:hint="0"
                        android:inputType="number" />

                    <EditText
                        android:id="@+id/etUnit"
                        style="@style/AdminFormInput"
                        android:layout_width="0dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:hint="Don vi: Hop, vi..."
                        android:inputType="textCapSentences" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_form_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/AdminFormSectionTitle"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Thông tin chi tiết" />

                    <LinearLayout
                        android:id="@+id/layoutPrescriptionChip"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_prescription_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp">

                        <TextView
                            android:id="@+id/tvPrescriptionLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cần đơn thuốc"
                            android:textColor="@color/prescription_off_text"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/cbRequiresPrescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            app:thumbTint="@color/prescription_switch_thumb"
                            app:trackTint="@color/prescription_switch_track" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="16dp"
                    android:text="Công dụng" />

                <EditText
                    android:id="@+id/etUses"
                    style="@style/AdminFormTextArea"
                    android:layout_marginTop="8dp"
                    android:hint="Công dụng và lợi ích chính của sản phẩm..."
                    android:inputType="textMultiLine" />

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="14dp"
                    android:text="Cách dùng" />

                <EditText
                    android:id="@+id/etUsage"
                    style="@style/AdminFormTextArea"
                    android:layout_marginTop="8dp"
                    android:hint="Hướng dẫn sử dụng và liều dùng..."
                    android:inputType="textMultiLine" />

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="14dp"
                    android:text="Tác dụng phụ" />

                <EditText
                    android:id="@+id/etSideEffects"
                    style="@style/AdminFormTextArea"
                    android:layout_marginTop="8dp"
                    android:hint="Các tác dụng phụ có thể gặp..."
                    android:inputType="textMultiLine" />

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="14dp"
                    android:text="Lưu ý" />

                <EditText
                    android:id="@+id/etPrecautions"
                    style="@style/AdminFormTextArea"
                    android:layout_marginTop="8dp"
                    android:hint="Các lưu ý, cảnh báo hoặc trường hợp cần thận trọng..."
                    android:inputType="textMultiLine" />

                <TextView
                    style="@style/AdminFormLabel"
                    android:layout_marginTop="14dp"
                    android:text="Bảo quản" />

                <EditText
                    android:id="@+id/etStorage"
                    style="@style/AdminFormTextArea"
                    android:layout_marginTop="8dp"
                    android:hint="Điều kiện bảo quản sản phẩm..."
                    android:inputType="textMultiLine" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@color/white"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelProduct"
            android:layout_width="92dp"
            android:layout_height="52dp"
            android:text="Hủy"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            app:backgroundTint="@color/surface_container_high"
            app:cornerRadius="6dp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Lưu sản phẩm"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="6dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/white"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
