<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:clipToPadding="false"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Screen Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lịch sử đơn hàng"
            android:textColor="@color/on_surface"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Theo dõi các đơn thuốc và sản phẩm của bạn"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <!-- Filter Tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tất cả"
                    android:textSize="13sp"
                    app:cornerRadius="100dp"
                    app:backgroundTint="@color/primary"
                    android:paddingHorizontal="20dp"/>

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Đang xử lý"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"
                    app:backgroundTint="@color/surface_container_high"
                    app:cornerRadius="100dp"
                    android:paddingHorizontal="20dp"/>

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Đang giao"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"
                    app:backgroundTint="@color/surface_container_high"
                    app:cornerRadius="100dp"
                    android:paddingHorizontal="20dp"/>

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Hoàn thành"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"
                    app:backgroundTint="@color/surface_container_high"
                    app:cornerRadius="100dp"
                    android:paddingHorizontal="20dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Order Cards Stack -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <!-- Order Card 1 (Hoàn thành) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MÃ ĐƠN HÀNG"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_variant"
                                android:letterSpacing="0.1" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#MC-9823410"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/round_corner_item"
                            android:backgroundTint="#1A4A6774"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Hoàn thành"
                            android:textColor="@color/on_secondary_container"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/surface_container_low">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_product"
                                android:scaleType="centerInside"
                                android:padding="8dp"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Viên uống hỗ trợ tim mạch Coenzyme Q10 + 2 mặt hàng khác"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:lineSpacingExtra="2dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ngày đặt: 12 Th04, 2024"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_container_high" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng thanh toán"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="545.000đ"
                                android:textColor="@color/on_surface"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Chi tiết"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                app:backgroundTint="@color/surface_container_high"
                                app:cornerRadius="8dp"
                                android:paddingHorizontal="16dp"
                                android:minWidth="0dp"/>

                            <com.google.android.material.button.MaterialButton
                                style="@style/Widget.Material3.Button"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:text="Mua lại"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/primary"
                                app:cornerRadius="8dp"
                                android:paddingHorizontal="16dp"
                                android:minWidth="0dp"/>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Order Card 2 (Đang giao) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MÃ ĐƠN HÀNG"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_variant"
                                android:letterSpacing="0.1" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#MC-9844201"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/round_corner_item"
                            android:backgroundTint="#1AA33500"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Đang giao"
                            android:textColor="@color/tertiary_container"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/surface_container_low">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_product"
                                android:scaleType="centerInside"
                                android:padding="8dp"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Nước súc miệng diệt khuẩn &amp; Khẩu trang N95"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:lineSpacingExtra="2dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ngày đặt: 18 Th04, 2024"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_container_high" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng thanh toán"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="182.000đ"
                                android:textColor="@color/on_surface"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Theo dõi"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="8dp"
                            android:paddingHorizontal="16dp"
                            android:minWidth="0dp"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Order Card 3 (Bento Style) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_history"
                                app:tint="@color/on_secondary_container" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Đơn hàng cũ - 05 Th04"
                                android:textColor="@color/on_surface_variant"
                                android:textStyle="bold"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="3"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="80dp"
                                android:layout_columnWeight="1"
                                android:layout_marginEnd="8dp"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@color/surface_container_high">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_product"
                                    android:padding="12dp"
                                    android:scaleType="centerInside"/>
                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="80dp"
                                android:layout_columnWeight="1"
                                android:layout_marginEnd="8dp"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@color/surface_container_high">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_product"
                                    android:padding="12dp"
                                    android:scaleType="centerInside"/>
                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="80dp"
                                android:layout_columnWeight="1"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@color/surface_container_lowest"
                                app:strokeWidth="1dp"
                                app:strokeColor="#4CC3C6D6">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="+2"
                                    android:gravity="center"
                                    android:textStyle="bold"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="12sp"/>
                            </com.google.android.material.card.MaterialCardView>
                        </GridLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.230.000đ"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Mua lại ngay"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:drawableStart="@drawable/ic_history"
                                android:drawablePadding="6dp"
                                app:drawableTint="@color/primary" />
                        </RelativeLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Help Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0D003D9B"> <!-- Primary with 5% alpha -->

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="60dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cần hỗ trợ về đơn hàng?"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Đội ngũ dược sĩ chuyên môn của chúng tôi luôn sẵn sàng giải đáp thắc mắc về liều dùng và vận chuyển."
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Liên hệ Dược sĩ →"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_hospital"
                    android:layout_gravity="bottom|end"
                    android:layout_marginBottom="-30dp"
                    android:layout_marginEnd="-30dp"
                    android:alpha="0.1"
                    android:rotation="12"
                    app:tint="@color/primary"/>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>