<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hồ sơ gian hàng"
            android:textColor="@color/on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:id="@+id/ivShopLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@color/secondary_container"
                android:contentDescription="Logo gian hàng" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thông tin hiển thị"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tên, mô tả, địa chỉ và logo sẽ được dùng trong kênh bán hàng."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/admin_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quản lý bán hàng"
                    android:textColor="@color/on_surface"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageProducts"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Sản phẩm"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:backgroundTint="@color/admin_light_green"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_product"
                        app:iconGravity="textTop"
                        app:iconPadding="6dp"
                        app:iconTint="@color/admin_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageOrders"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Đơn hàng"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:backgroundTint="@color/light_blue"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_history"
                        app:iconGravity="textTop"
                        app:iconPadding="6dp"
                        app:iconTint="@color/main_blue" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageAds"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Quảng cáo"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:backgroundTint="@color/prescription_on_bg"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_uudai"
                        app:iconGravity="textTop"
                        app:iconPadding="6dp"
                        app:iconTint="@color/tertiary_container" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <EditText
            android:id="@+id/etShopName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:hint="Tên gian hàng"
            android:inputType="textCapWords"
            android:paddingHorizontal="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etShopDescription"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:gravity="top"
            android:hint="Mô tả gian hàng"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etShopAddress"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:hint="Địa chỉ"
            android:inputType="textPostalAddress"
            android:paddingHorizontal="14dp"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etShopLogo"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_corner_item"
            android:backgroundTint="@color/white"
            android:hint="Link logo"
            android:inputType="textUri"
            android:paddingHorizontal="14dp"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveShop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Lưu thông tin"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuyerChannel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Kênh mua hàng"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />
    </LinearLayout>
</ScrollView>
